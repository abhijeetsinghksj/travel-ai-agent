# ============================================================
# TRAVEL AI AGENT - Environment Configuration
# ============================================================

# ---- LLM Provider (Choose ONE) ----
# Option 1: Groq (Free, Fast, Open-source models)
GROQ_API_KEY=your_groq_api_key_here
# Model options: llama3-70b-8192 | mixtral-8x7b-32768 | llama3-8b-8192
LLM_MODEL=llama3-70b-8192

# Option 2: Ollama (Fully local, no API key needed)
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3

# ---- Google Calendar ----
# Download credentials.json from Google Cloud Console
# https://console.cloud.google.com/apis/credentials
GOOGLE_CREDENTIALS_PATH=./config/credentials.json
GOOGLE_TOKEN_PATH=./config/token.json
GOOGLE_CALENDAR_ID=primary

# ---- Flight Search (Amadeus - Free Tier) ----
# Register at: https://developers.amadeus.com/
AMADEUS_CLIENT_ID=your_amadeus_client_id
AMADEUS_CLIENT_SECRET=your_amadeus_client_secret
AMADEUS_HOSTNAME=test  # Use 'production' for live data

# ---- App Settings ----
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=true

# ---- User Home City (for flight searches) ----
HOME_CITY=Delhi
HOME_AIRPORT=DEL
